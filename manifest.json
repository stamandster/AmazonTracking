{
  "manifest_version": 3,
  "name": "AmazonTracking",
  "version": "1.0",
  "description": "Track Amazon orders and spending",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": [
    "*://*.amazon.com/*"
  ],
  "action": {
    "default_title": "AmazonTracking"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/gp/your-account/*", "*://*.amazon.com/*order-details*", "*://*.amazon.com/cpe/yourpayments/transactions*", "*://*.amazon.com/your-orders/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
